[
  {
    "type": "function",
    "function": {
      "name": "send_invoice",
      "description": "Generate an invoice PDF, upload to Google Drive, and send via email to the client",
      "parameters": {
        "type": "object",
        "properties": {
          "client_name":  { "type": "string", "description": "Client full name in nominative form" },
          "client_email": { "type": "string", "description": "Client email address" },
          "property_id":  { "type": "string", "description": "Property ID like 'apt-3' or 'house-12'" },
          "amount":       { "type": "number", "description": "Invoice amount in euros" },
          "language":     { "type": "string", "enum": ["lv", "ru", "en"], "description": "Language for invoice and email" },
          "notes":        { "type": "string", "description": "Optional additional notes" }
        },
        "required": ["client_name", "client_email", "property_id", "amount", "language"]
      }
    }
  },
  {
