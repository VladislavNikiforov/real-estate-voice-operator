# Server
PORT=8000
LOG_LEVEL=DEBUG

# Gmail OAuth2 (run: python scripts/gmail_setup.py)
# Download credentials from Google Cloud Console → save as credentials/gmail_credentials.json
# Token auto-generated at credentials/gmail_token.json after running setup script
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json

# Google Drive (optional — falls back to local files if not set)
GDRIVE_CREDENTIALS_PATH=credentials/gdrive_service_account.json
GDRIVE_FOLDER_ID=your_folder_id_here

# Claude API (brain for /api/chat)
ANTHROPIC_API_KEY=your_anthropic_api_key

# SMTP (direct email sending — optional, logs to console if not set)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com

# Notion — Company OS (client & service database)
NOTION_TOKEN=your_notion_integration_token
NOTION_CLIENTS_DB=32e9f35f-e2f9-80d0-90b8-f3349c66d6f1
NOTION_SERVICES_DB=32e9f35f-e2f9-8011-b1b4-c96ce2fd19ca

# Company info (seller on invoices)
COMPANY_NAME=SIA "TEIKUMS JT"
COMPANY_REG_NR=40203653629
COMPANY_VAT_NR=LV40203653629
COMPANY_ADDRESS=Gustava Zemgala gatve 78-1, Rīga, LV-1039
COMPANY_PHONE=+371 20000000
COMPANY_EMAIL=info@teikums.lv
COMPANY_BANK=Swedbank
COMPANY_IBAN=LV00HABA0000000000000

# Telegram notification bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
