# Server
PORT=8000
LOG_LEVEL=DEBUG

# Gmail OAuth2 (run: python scripts/gmail_setup.py)
# Download credentials from Google Cloud Console → save as credentials/gmail_credentials.json
# Token auto-generated at credentials/gmail_token.json after running setup script
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json

# Google Drive (optional — falls back to local files if not set)
GDRIVE_CREDENTIALS_PATH=credentials/gdrive_service_account.json
GDRIVE_FOLDER_ID=your_folder_id_here

# Company info (used in invoices and emails)
COMPANY_NAME=Demo Real Estate SIA
COMPANY_ADDRESS=Brīvības iela 100, Rīga, LV-1001
COMPANY_PHONE=+371 20000000
COMPANY_EMAIL=info@demo-realestate.lv
COMPANY_BANK=Swedbank
COMPANY_IBAN=LV00HABA0000000000000

# Telegram notification bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
